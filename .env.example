# Copy this file to .env and fill in your values.
# .env is loaded automatically by `python -m voice2json`.

# ── LLM provider ──────────────────────────────────────────────────────────
LLM_PROVIDER=anthropic          # anthropic | openai
ANTHROPIC_API_KEY=sk-ant-...    # required for anthropic
# OPENAI_API_KEY=sk-...         # required for openai

# Optional: override default model per provider
# LLM_MODEL=claude-sonnet-4-6
# LLM_MODEL=gpt-4o-mini

# LLM temperature (0.0 – 1.0, default 0.1 for determinism)
# LLM_TEMPERATURE=0.1

# ── Whisper ───────────────────────────────────────────────────────────────
# Model size: tiny | base | small | medium | large-v2 | large-v3
# Smaller = faster but less accurate.  'base' is a good default.
WHISPER_MODEL=base

# ── Vision (Phase 2) ──────────────────────────────────────────────────────
# Vision-capable Claude model (sonnet and opus both support vision)
# CLAUDE_MODEL=claude-sonnet-4-6

# Webcam capture mode: manual (press SPACE) or auto (capture immediately)
# VISION_CAPTURE_MODE=manual

# Webcam device index (default 0 = first camera)
# VISION_CAMERA_ID=0

# Below this confidence the model will ask for confirmation (default 0.6)
# VISION_CONFIDENCE_THRESHOLD=0.6

# ── Paths ─────────────────────────────────────────────────────────────────
# Where to save run logs (default: ./runs)
# RUNS_DIR=runs
